<?xml version="1.0" encoding="utf-8"?>
<!-- Foreground drawable for the adaptive icon.
     The existing ic_launcher PNG is used as the foreground image.
     Android's launcher applies a squircle/rounded shape mask on top of this. -->
<bitmap xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:src="@mipmap/ic_launcher"
    android:tileMode="disabled" />
